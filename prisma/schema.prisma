generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  
  rootPersonId  String?   @unique
  rootPerson    Person?   @relation("UserRootPerson", fields: [rootPersonId], references: [id])
  currentGraphId String?
  currentGraph   FamilyGraph? @relation("UserCurrentGraph", fields: [currentGraphId], references: [id])
  
  createdPeople Person[]  @relation("CreatedBy")
  contributedLayers PersonLayer[]
  sentInvitations Invitation[]
  personLinks   UserPersonLink[]
  personClaims  PersonClaim[] @relation("PersonClaimContributor")
  relationshipClaims RelationshipClaim[] @relation("RelationshipClaimContributor")
  createdPersonLinks PersonLink[] @relation("PersonLinkCreatedBy")
  resolutionCases ResolutionCase[] @relation("ResolutionCaseCreatedBy")
  adminGraphs   FamilyGraph[] @relation("GraphAdmin")
  graphMemberships GraphMembership[] @relation("GraphMembershipUser")
  sentGraphInvitations GraphInvitation[] @relation("GraphInvitationInviter")
  receivedGraphInvitations GraphInvitation[] @relation("GraphInvitationInvitee")
  graphAuditLogs GraphAuditLog[] @relation("GraphAuditActor")
  invitedGraphMemberships GraphMembership[] @relation("GraphMembershipInvitedBy")
  passwordResetTokens PasswordResetToken[]
  
  accounts      Account[]
  sessions      Session[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  email      String
  token      String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model Person {
  id          String    @id @default(cuid())
  graphId      String?
  firstName   String
  lastName    String?
  middleName  String?
  nickName    String?
  title       String?
  gender      String?
  
  dateOfBirth DateTime?
  placeOfBirth String?
  dateOfDeath DateTime?
  placeOfDeath String?
  
  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])
  graph       FamilyGraph? @relation("GraphPeople", fields: [graphId], references: [id])
  
  linkedUserId String? @unique
  linkedUser   User?   @relation("UserRootPerson")
  rootOfGraph  FamilyGraph? @relation("GraphRootPerson")
  
  // Relationships via Family
  // The family this person is a child of
  childOfFamilyId String?
  childOfFamily   Family? @relation("FamilyChildren", fields: [childOfFamilyId], references: [id])

  // Families where this person is a parent (Partner/Spouse)
  familiesAsParent1 Family[] @relation("FamilyParent1")
  familiesAsParent2 Family[] @relation("FamilyParent2")

  // Personal events (Birth, Death)
  events       FamilyEvent[] @relation("PersonEvents")
  
  photos      Photo[]
  invitations Invitation[]
  layers      PersonLayer[]
  userLinks   UserPersonLink[]
  claims      PersonClaim[]
  outgoingRelationships RelationshipClaim[] @relation("RelationshipFromPerson")
  incomingRelationships RelationshipClaim[] @relation("RelationshipToPerson")
  leftLinks   PersonLink[] @relation("PersonLinkLeft")
  rightLinks  PersonLink[] @relation("PersonLinkRight")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PersonLayer {
  id            String    @id @default(cuid())
  personId      String
  person        Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  
  // Data fields (snapshot of Person fields)
  firstName     String?
  lastName      String?
  middleName    String?
  nickName      String?
  title         String?
  gender        String?
  dateOfBirth   DateTime?
  placeOfBirth  String?
  dateOfDeath   DateTime?
  placeOfDeath  String?
  
  // Meta
  contributorId String? 
  contributor   User?     @relation(fields: [contributorId], references: [id])
  
  relationshipDistance Int? // 0=Self, 1=Parent/Child, etc.
  confidenceScore      Float @default(1.0)
  
  createdAt     DateTime  @default(now())
}

model Family {
  id          String   @id @default(cuid())
  graphId     String?
  graph       FamilyGraph? @relation("GraphFamilies", fields: [graphId], references: [id])

  parent1Id   String?
  parent1     Person?  @relation("FamilyParent1", fields: [parent1Id], references: [id])

  parent2Id   String?
  parent2     Person?  @relation("FamilyParent2", fields: [parent2Id], references: [id])

  children    Person[] @relation("FamilyChildren")

  events      FamilyEvent[] @relation("FamilyEvents") // Marriage, Divorce

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FamilyEvent {
  id          String   @id @default(cuid())
  type        String   // BIRTH, DEATH, MARRIAGE, DIVORCE
  date        DateTime?
  place       String?
  description String?
  
  // Event can belong to a Person (Birth, Death)
  personId    String?
  person      Person?  @relation("PersonEvents", fields: [personId], references: [id], onDelete: Cascade)
  
  // OR Event can belong to a Family (Marriage, Divorce)
  familyId    String?
  family      Family?  @relation("FamilyEvents", fields: [familyId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Photo {
  id          String   @id @default(cuid())
  url         String
  caption     String?
  date        DateTime?
  data        Bytes?
  mimeType    String?
  personId    String
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  token     String   @unique
  status    String   @default("PENDING") 
  inviterId String
  inviter   User     @relation(fields: [inviterId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FamilyGraph {
  id            String   @id @default(cuid())
  name          String
  adminUserId   String
  rootPersonId  String?  @unique
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  adminUser     User     @relation("GraphAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  rootPerson    Person?  @relation("GraphRootPerson", fields: [rootPersonId], references: [id])
  currentUsers  User[]   @relation("UserCurrentGraph")
  people        Person[] @relation("GraphPeople")
  families      Family[] @relation("GraphFamilies")
  memberships   GraphMembership[]
  invitations   GraphInvitation[]
  auditLogs     GraphAuditLog[]

  @@index([adminUserId, status])
}

model GraphMembership {
  id             String   @id @default(cuid())
  graphId        String
  userId         String
  role           String   @default("EDITOR")
  status         String   @default("ACTIVE")
  invitedByUserId String?
  invitationId   String?
  lastSeenAt     DateTime?
  lastActivityAt DateTime?
  currentPersonId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  graph          FamilyGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)
  user           User        @relation("GraphMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy      User?       @relation("GraphMembershipInvitedBy", fields: [invitedByUserId], references: [id])

  @@unique([graphId, userId])
  @@index([graphId, status, role])
}

model GraphInvitation {
  id             String   @id @default(cuid())
  graphId        String
  email          String
  role           String   @default("EDITOR")
  token          String   @unique
  status         String   @default("PENDING")
  invitedByUserId String
  invitedUserId  String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  graph          FamilyGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)
  invitedBy      User        @relation("GraphInvitationInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  invitedUser    User?       @relation("GraphInvitationInvitee", fields: [invitedUserId], references: [id])

  @@index([graphId, status, expiresAt])
  @@index([email, status])
}

model GraphAuditLog {
  id             String   @id @default(cuid())
  graphId        String
  actorUserId    String?
  action         String
  entityType     String
  entityId       String?
  detailsJson    Json?
  createdAt      DateTime @default(now())

  graph          FamilyGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)
  actorUser      User?       @relation("GraphAuditActor", fields: [actorUserId], references: [id])

  @@index([graphId, createdAt])
  @@index([action, entityType])
}

model UserPersonLink {
  id               String   @id @default(cuid())
  userId           String
  personId         String
  role             String   @default("CONTRIBUTOR")
  status           String   @default("ACTIVE")
  assertedDistance Int?
  computedDistance Int?
  distancePath     Json?
  invitedByUserId  String?
  invitationId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  person           Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([userId, personId])
  @@index([personId, computedDistance])
  @@index([userId, status])
}

model PersonClaim {
  id                 String   @id @default(cuid())
  personId           String
  field              String
  valueJson          Json
  contributorId      String?
  sourceType         String   @default("USER")
  sourceRefId        String?
  assertedDistance   Int?
  computedDistance   Int?
  confidenceScore    Float    @default(1.0)
  corroborationScore Float    @default(0)
  resolutionStatus   String   @default("ACTIVE")
  supersedesClaimId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  person             Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  contributor        User?    @relation("PersonClaimContributor", fields: [contributorId], references: [id])

  @@index([personId, field, resolutionStatus])
  @@index([contributorId, createdAt])
}

model RelationshipClaim {
  id                 String   @id @default(cuid())
  fromPersonId       String
  toPersonId         String
  relationshipType   String
  contributorId      String?
  sourceType         String   @default("USER")
  sourceRefId        String?
  assertedDistance   Int?
  computedDistance   Int?
  confidenceScore    Float    @default(1.0)
  resolutionStatus   String   @default("ACTIVE")
  validFrom          DateTime?
  validTo            DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  fromPerson         Person   @relation("RelationshipFromPerson", fields: [fromPersonId], references: [id], onDelete: Cascade)
  toPerson           Person   @relation("RelationshipToPerson", fields: [toPersonId], references: [id], onDelete: Cascade)
  contributor        User?    @relation("RelationshipClaimContributor", fields: [contributorId], references: [id])

  @@index([fromPersonId, relationshipType, resolutionStatus])
  @@index([toPersonId, relationshipType, resolutionStatus])
}

model PersonLink {
  id               String   @id @default(cuid())
  leftPersonId     String
  rightPersonId    String
  linkType         String   @default("POSSIBLE_SAME")
  sourceType       String   @default("SYSTEM")
  confidenceScore  Float    @default(0)
  resolutionStatus String   @default("OPEN")
  createdByUserId  String?
  resolutionCaseId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  leftPerson       Person   @relation("PersonLinkLeft", fields: [leftPersonId], references: [id], onDelete: Cascade)
  rightPerson      Person   @relation("PersonLinkRight", fields: [rightPersonId], references: [id], onDelete: Cascade)
  createdBy        User?    @relation("PersonLinkCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([leftPersonId, rightPersonId])
  @@index([resolutionStatus, linkType])
}

model ResolutionCase {
  id               String   @id @default(cuid())
  entityType       String
  entityRefId      String
  field            String?
  status           String   @default("OPEN")
  rationaleJson    Json?
  createdByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy        User?    @relation("ResolutionCaseCreatedBy", fields: [createdByUserId], references: [id])

  @@index([entityType, entityRefId, status])
}
